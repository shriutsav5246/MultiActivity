<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calculatorBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBackCalculator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:padding="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculator"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/calculator_display_bg"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp">

        <HorizontalScrollView
            android:id="@+id/expressionScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <TextView
                android:id="@+id/tvExpression"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="28sp" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:text="0"
            android:textColor="#9CA3AF"
            android:textSize="40sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:columnCount="4">

        <Button android:id="@+id/btnClear" style="@style/CalcSpecial" android:text="C"/>
        <Button android:id="@+id/btnBackspace" style="@style/CalcSpecial" android:text="⌫"/>
        <Button android:id="@+id/btnParenthesis" style="@style/CalcSpecial" android:text="()"/>
        <Button android:id="@+id/btnPercent" style="@style/CalcSpecial" android:text="%"/>

        <Button android:id="@+id/btn7" style="@style/CalcNumber" android:text="7"/>
        <Button android:id="@+id/btn8" style="@style/CalcNumber" android:text="8"/>
        <Button android:id="@+id/btn9" style="@style/CalcNumber" android:text="9"/>
        <Button android:id="@+id/btnDivide" style="@style/CalcOperator" android:text="÷"/>

        <Button android:id="@+id/btn4" style="@style/CalcNumber" android:text="4"/>
        <Button android:id="@+id/btn5" style="@style/CalcNumber" android:text="5"/>
        <Button android:id="@+id/btn6" style="@style/CalcNumber" android:text="6"/>
        <Button android:id="@+id/btnMultiply" style="@style/CalcOperator" android:text="×"/>

        <Button android:id="@+id/btn1" style="@style/CalcNumber" android:text="1"/>
        <Button android:id="@+id/btn2" style="@style/CalcNumber" android:text="2"/>
        <Button android:id="@+id/btn3" style="@style/CalcNumber" android:text="3"/>
        <Button android:id="@+id/btnMinus" style="@style/CalcOperator" android:text="-"/>

        <Button android:id="@+id/btnDot" style="@style/CalcNumber" android:text="."/>
        <Button android:id="@+id/btn0" style="@style/CalcNumber" android:text="0"/>
        <Button android:id="@+id/btnEquals" style="@style/CalcEquals" android:text="="/>
        <Button android:id="@+id/btnPlus" style="@style/CalcOperator" android:text="+"/>

    </GridLayout>

</LinearLayout>