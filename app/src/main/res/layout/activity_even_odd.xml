<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calculatorBackground"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBackEvenOdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:padding="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Even / Odd Specifier"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvEvenOddSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Number Parity Detection"
        android:textColor="#9CA3AF"
        android:textSize="16sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="40dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/calculator_display_bg"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/etNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Integer Number"
            android:textColorHint="#9CA3AF"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:background="@android:color/transparent"
            android:inputType="numberSigned" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/calculator_display_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for Input"
            android:textColor="#9CA3AF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="..."
            android:textColor="@color/white"
            android:textSize="42sp"
            android:textStyle="bold" />

    </LinearLayout>

    <Button
        android:id="@+id/btnClearEvenOdd"
        android:layout_width="220dp"
        android:layout_height="70dp"
        android:layout_marginTop="40dp"
        android:text="CLEAR"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:backgroundTint="#DC2626" />

</LinearLayout>