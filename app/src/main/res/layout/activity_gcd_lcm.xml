<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#081225"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBackGcdLcm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GCD / LCM Finder"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/calculator_display_bg"
        android:padding="24dp"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Integers (comma separated)"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNumbers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="#1F2937"
            android:hint="Example: 5,15,35,80"
            android:textColorHint="#9CA3AF"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:inputType="text" />

        <Button
            android:id="@+id/btnClearGcdLcm"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="CLEAR"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#DC2626"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/calculator_display_bg"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvGcdResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GCD: -"
                android:textColor="#22C55E"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLcmResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LCM: -"
                android:textColor="#06B6D4"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp" />

            <TextView
                android:id="@+id/tvSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Steps: -"
                android:textColor="#F59E0B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>