<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calculatorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBackPrime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prime Number Specifier"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Prime Analysis"
            android:textColor="#9CA3AF"
            android:textSize="15sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/calculator_display_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/etPrimeNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Integer Number"
                android:textColorHint="#9CA3AF"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:background="@android:color/transparent"
                android:inputType="number" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/calculator_display_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvPrimeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for Input"
                android:textColor="#9CA3AF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPrimeResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="..."
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/calculator_display_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prime Numbers from 0 to N"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tvPrimeList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="#D1D5DB"
                    android:textSize="16sp" />
            </ScrollView>

        </LinearLayout>

        <Button
            android:id="@+id/btnClearPrime"
            android:layout_width="220dp"
            android:layout_height="70dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:text="CLEAR"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:backgroundTint="#DC2626" />

    </LinearLayout>

</ScrollView>